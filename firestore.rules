rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isMasterAdmin() {
      return isSignedIn() &&
             request.auth.token.get('email', '').lower() == 'kalianrobot@gmail.com';
    }

    function isAdmin() {
      return isMasterAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isTeacher() {
      return isMasterAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'profesor', 'teacher_admin']
      );
    }

    function isPortero() {
      return isMasterAdmin() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'portero'
      );
    }

    function isTeacherOfCourse(cursoId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/cursos/$(cursoId)) &&
             get(/databases/$(database)/documents/cursos/$(cursoId)).data.profesorId == request.auth.uid;
    }

    // --- GLOBAL SAFETY NET (solo master admin) ---
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // --- USERS ---
    // C1: el campo 'role' sólo puede ser modificado por un admin. El usuario puede crear y
    // mantener su propio perfil pero nunca tocar 'role'.
    match /users/{userId} {
      // Users can read their own profile but cannot self-assign roles
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId
                    && !incoming().keys().hasAny(['role']);
      allow update: if (isSignedIn() && request.auth.uid == userId
                        && !incoming().diff(existing()).affectedKeys().hasAny(['role']))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // --- CONFIG público (lectura abierta, escritura admin) ---
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- CONFIGURACION interna (lectura/escritura sólo admin) ---
    match /configuracion/{id} {
      allow read, write: if isAdmin();
    }

    // --- CURSOS ---
    function isValidCurso(data) {
      return data.titulo is string && data.titulo.size() <= 200
          && (!data.keys().hasAny(['titulo_eu'])       || (data.titulo_eu is string       && data.titulo_eu.size() <= 200))
          && (!data.keys().hasAny(['descripcion_eu'])  || (data.descripcion_eu is string  && data.descripcion_eu.size() <= 2000))
          && (!data.keys().hasAny(['horario_eu'])      || (data.horario_eu is string      && data.horario_eu.size() <= 500))
          && (!data.keys().hasAny(['ventajas_eu'])     || (data.ventajas_eu is string     && data.ventajas_eu.size() <= 1000))
          && (!data.keys().hasAny(['subcategoria_eu']) || (data.subcategoria_eu is string && data.subcategoria_eu.size() <= 100));
    }
    match /cursos/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidCurso(incoming());
      allow update: if (isAdmin() && isValidCurso(incoming()))
                    || (isTeacher() && incoming().diff(existing()).affectedKeys().hasOnly(['alumnos', 'aforo_actual']));
      allow delete: if isAdmin();
    }

    // --- SESIONES ---
    match /cursos/{cursoId}/sesiones/{sId} {
      allow read, list: if true;
      allow write: if isAdmin() || isTeacherOfCourse(cursoId);
    }
    match /{path=**}/sesiones/{sId} {
      allow read, list: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // --- EVENTOS ---
    function isValidEvento(data) {
      return data.titulo is string && data.titulo.size() <= 200
          && (!data.keys().hasAny(['aforo_maximo']) || data.aforo_maximo is number)
          && (!data.keys().hasAny(['aforo_max']) || data.aforo_max is number)
          && (!data.keys().hasAny(['aforo_reservado']) || data.aforo_reservado is number)
          && (!data.keys().hasAny(['titulo_eu'])      || (data.titulo_eu is string      && data.titulo_eu.size() <= 200))
          && (!data.keys().hasAny(['descripcion_eu']) || (data.descripcion_eu is string && data.descripcion_eu.size() <= 2000))
          && (!data.keys().hasAny(['reglas_eu'])      || (data.reglas_eu is string      && data.reglas_eu.size() <= 2000));
    }
    // C4: una actualización pública sólo puede aumentar 'aforo_reservado' en pasos acotados
    // y nunca por encima del aforo máximo. Bloquea reset a 0 / valores arbitrarios.
    function isSafeAforoUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['aforo_reservado'])
          && incoming().aforo_reservado is number
          && incoming().aforo_reservado >= int(existing().get('aforo_reservado', 0))
          && incoming().aforo_reservado <= int(existing().get('aforo_reservado', 0)) + 20
          && incoming().aforo_reservado <= int(existing().get('aforo_maximo', existing().get('aforo_max', 9999)));
    }
    // Portero solo puede ajustar aforos, y con tipos válidos (Sprint 3 — higiene)
    function isPorteroAforoUpdate() {
      return isPortero()
          && incoming().diff(existing()).affectedKeys().hasOnly(['aforo_actual', 'aforo_reservado'])
          && (!incoming().keys().hasAny(['aforo_actual']) || incoming().aforo_actual is number)
          && (!incoming().keys().hasAny(['aforo_reservado']) || incoming().aforo_reservado is number);
    }
    match /eventos/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvento(incoming());
      allow delete: if isAdmin();
      allow update: if (isAdmin() && isValidEvento(incoming()))
                    || isSafeAforoUpdate()
                    || isPorteroAforoUpdate();
    }

    // --- RESERVAS ---
    // Sprint 3: allowlist de claves (hasOnly) + email regex.
    // Mantiene cobertura de los campos legítimos que escribe ReservaForm.tsx;
    // rechaza payloads con campos arbitrarios (defensa contra payload #2 de Dirty Dozen).
    function isValidReserva(data) {
      return data.keys().hasOnly([
              'eventoId', 'eventoTitulo', 'categoria',
              'uidTitular', 'dniTitular', 'nombreTitular', 'emailTitular',
              'ticketID', 'manageToken', 'qrUrl',
              'numPersonas', 'totalPagar', 'totalPendiente',
              'fechaReserva', 'fechaActividad',
              'slots', 'esCurso', 'acompañantes',
              'asistentes_ingresados', 'cuponUsado', 'esSocio'
          ])
          && data.eventoId is string && data.eventoId.size() <= 128
          && data.nombreTitular is string && data.nombreTitular.size() > 0 && data.nombreTitular.size() <= 200
          && data.dniTitular is string && (data.dniTitular.size() == 0 || (data.dniTitular.size() >= 7 && data.dniTitular.size() <= 20))
          && data.emailTitular is string && data.emailTitular.size() <= 100 && data.emailTitular.matches('.+@.+\\..+')
          && data.numPersonas is number && data.numPersonas >= 1 && data.numPersonas <= 20
          && data.uidTitular is string
          && (data.uidTitular == 'invitado' || data.uidTitular == request.auth.uid);
    }
    match /reservas/{id} {
      // C3: se mantiene el flujo de invitado pero con validación más estricta del payload
      allow create: if isValidReserva(incoming()) &&
                    (exists(/databases/$(database)/documents/eventos/$(incoming().eventoId)) ||
                     exists(/databases/$(database)/documents/cursos/$(incoming().eventoId)));
      // C2: SIN la cláusula 'dniTitular != null' que permitía lectura pública total
      allow read: if isAdmin()
                  || isPortero()
                  || (isSignedIn() && resource.data.uidTitular == request.auth.uid)
                  || (isSignedIn() && resource.data.get('emailTitular', '').lower() == request.auth.token.get('email', '').lower());
      allow update: if isAdmin() || isPortero()
                    || (isSignedIn()
                        && resource.data.uidTitular == request.auth.uid
                        && incoming().diff(existing()).affectedKeys().hasOnly(['acompañantes']));
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.uidTitular == request.auth.uid);
    }

    // --- SOCIOS ---
    // A4: cualquier signed-in podía crear un socio con cualquier uid; ahora se exige
    // coincidencia con request.auth.uid y forma mínima válida.
    function isValidSocioCreate(data) {
      return data.uid is string && data.uid == request.auth.uid
          && data.dni is string && data.dni.size() > 0 && data.dni.size() <= 20
          && data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 200
          && data.email is string && data.email.size() <= 100;
    }
    match /socios/{id} {
      // Allow querying by uid OR email (PerfilSocio uses both as fallback).
      // Sprint 3: comparación de email en minúsculas, consistente con reservas.
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        resource.data.get('email', '').lower() == request.auth.token.get('email', '').lower() ||
        isAdmin() || isPortero() ||
        isTeacher()
      );
      allow create: if isAdmin() || (isSignedIn() && isValidSocioCreate(incoming()));
      allow update, delete: if isAdmin();
    }

    // --- OTROS PÚBLICOS ---
    function isValidProfesor(data) {
      return (!data.keys().hasAny(['nombre_eu'])       || (data.nombre_eu is string       && data.nombre_eu.size() <= 200))
          && (!data.keys().hasAny(['especialidad_eu']) || (data.especialidad_eu is string && data.especialidad_eu.size() <= 200));
    }
    function isValidExposicion(data) {
      return (!data.keys().hasAny(['titulo_eu'])      || (data.titulo_eu is string      && data.titulo_eu.size() <= 200))
          && (!data.keys().hasAny(['autor_eu'])       || (data.autor_eu is string       && data.autor_eu.size() <= 200))
          && (!data.keys().hasAny(['descripcion_eu']) || (data.descripcion_eu is string && data.descripcion_eu.size() <= 2000));
    }
    match /academias/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /profesores/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProfesor(incoming());
      allow delete: if isAdmin();
    }
    match /exposiciones/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidExposicion(incoming());
      allow delete: if isAdmin();
    }
    match /locales/{id}      { allow read: if true; allow write: if isAdmin(); }

    // --- SOLICITUDES CURSOS ---
    // A3/A7: alta pública con validación de forma y longitudes.
    // Sprint 3: hasOnly para impedir campos arbitrarios.
    function isValidSolicitud(data) {
      return data.keys().hasOnly([
              'nombre', 'email', 'mensaje', 'telefono', 'dni',
              'cursoId', 'cursoTitulo', 'categoria', 'subcategoria',
              'modalidad', 'tipo', 'fechaSolicitud', 'estado'
          ])
          && data.keys().hasAll(['nombre', 'email'])
          && data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 200
          && data.email is string && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
          && (!data.keys().hasAny(['mensaje']) || (data.mensaje is string && data.mensaje.size() <= 2000))
          && (!data.keys().hasAny(['telefono']) || (data.telefono is string && data.telefono.size() <= 30))
          && (!data.keys().hasAny(['dni']) || (data.dni is string && data.dni.size() <= 20))
          && (!data.keys().hasAny(['cursoId']) || (data.cursoId is string && data.cursoId.size() <= 128))
          && (!data.keys().hasAny(['cursoTitulo']) || (data.cursoTitulo is string && data.cursoTitulo.size() <= 200))
          && (!data.keys().hasAny(['estado']) || data.estado == 'pendiente');
    }
    match /solicitudes_cursos/{id} {
      allow create: if isValidSolicitud(incoming());
      allow read, write: if isAdmin() || isTeacher();
    }

    // --- NEWSLETTER ---
    // A8: faltaba regla; se añade alta pública validada y lectura sólo admin.
    // El alta pública sólo puede crear el documento en estado 'pendiente_confirmacion':
    // la promoción a 'activo' la realiza Cloud Functions tras el doble opt-in de Brevo.
    function isValidNewsletter(data) {
      return data.keys().hasOnly(['nombre', 'email', 'acepto_terminos', 'politica_version', 'estado', 'fecha', 'ip'])
          && data.keys().hasAll(['nombre', 'email', 'acepto_terminos'])
          && data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 100
          && data.email is string && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
          && data.acepto_terminos == true
          && (!data.keys().hasAny(['politica_version']) || (data.politica_version is string && data.politica_version.size() <= 20))
          && (!data.keys().hasAny(['estado']) || data.estado == 'pendiente_confirmacion')
          && (!data.keys().hasAny(['ip']) || (data.ip is string && data.ip.size() <= 64));
    }
    match /newsletter_subscribers/{id} {
      allow create: if isValidNewsletter(incoming());
      allow read, update, delete: if isAdmin();
    }

    // --- FINANZAS / CAJA ---
    // Sprint 3: forma mínima de pagos_mensuales validada server-side.
    // El ID convencional es `${anio}_${mes}_${socioId}` (ver TeacherDashboard y AdminSocios).
    function isValidPagoMensual(data) {
      return data.keys().hasOnly([
              'socioId', 'mes', 'anio', 'pagado', 'bloqueado', 'monto',
              'cursoId', 'profesorId', 'localId', 'metodo',
              'actualizadoPor', 'fechaActualizacion'
          ])
          && data.socioId is string && data.socioId.size() > 0 && data.socioId.size() <= 128
          && data.mes is number && data.mes >= 1 && data.mes <= 12
          && data.anio is number && data.anio >= 2024 && data.anio <= 2100
          && (!data.keys().hasAny(['pagado']) || data.pagado is bool)
          && (!data.keys().hasAny(['bloqueado']) || data.bloqueado is bool)
          && (!data.keys().hasAny(['monto']) || data.monto is number);
    }
    match /finanzas/{id}              { allow read: if isAdmin(); allow write: if isAdmin() || isPortero(); }
    match /pagos_mensuales/{id} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if (isAdmin() || isTeacher() || isPortero()) && isValidPagoMensual(incoming());
      allow update: if (isAdmin() || isTeacher() || isPortero()) && isValidPagoMensual(incoming());
      allow delete: if isAdmin();
    }
    match /pagos_inscripciones/{id}   { allow read, write: if isAdmin() || isTeacher(); }
    match /caja_eventos/{id}          { allow read, write: if isAdmin() || isPortero(); }
    match /asistencia_eventos/{id}    { allow read, create: if isAdmin() || isPortero(); }

    // --- NOTIFICACIONES ---
    // A5: cualquier signed-in podía sobreescribir/borrar notificaciones de otros. Restringido al dueño.
    match /notificaciones/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // --- ASISTENCIA EVENTOS (teachers can also manage for class attendance) ---
    match /asistencia_eventos/{id} {
      allow read, write: if isAdmin() || isPortero() || isTeacher();
    }
  }
}
