{
  "entities": {
    "profesores": {
      "title": "Profesor",
      "description": "Información de los profesores de la asociación",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID de Firebase Auth" },
        "nombre": { "type": "string", "description": "Nombre completo" },
        "email": { "type": "string", "format": "email" },
        "especialidad": { "type": "string" },
        "activo": { "type": "boolean" }
      },
      "required": ["uid", "nombre", "email"]
    },
    "cursos": {
      "title": "Curso",
      "description": "Cursos y talleres ofrecidos",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "profesorId": { "type": "string", "description": "UID del profesor asignado" },
        "profesorNombre": { "type": "string" },
        "categoria": { "type": "string", "enum": ["musica", "danza", "local"] },
        "subcategoria": { "type": "string", "description": "Subcategoría para filtrado (Instrumento, Salsa, etc.)" },
        "modalidades": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tipo": { "type": "string", "enum": ["presencial", "online"] },
              "frecuencia": { "type": "string", "enum": ["semanal", "quincenal", "mensual"] },
              "precio": { "type": "number" }
            }
          }
        },
        "alumnos": { "type": "array", "items": { "type": "string" }, "description": "Lista de DNIs de alumnos" },
        "aforo_disponible": { "type": "boolean" },
        "aforo_actual": { "type": "number" },
        "horario": { "type": "string" },
        "fechaInicio": { "type": "string", "format": "date" },
        "fechaFin": { "type": "string", "format": "date" },
        "ventajas": { "type": "string", "description": "Texto de ventajas de branding" }
      }
    },
    "solicitudes_cursos": {
      "title": "Solicitud de Curso",
      "description": "Consultas e inscripciones a cursos de la academia",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefono": { "type": "string" },
        "dni": { "type": "string", "description": "Opcional para consultas, obligatorio para inscripciones" },
        "mensaje": { "type": "string" },
        "cursoId": { "type": "string" },
        "cursoTitulo": { "type": "string" },
        "categoria": { "type": "string" },
        "subcategoria": { "type": "string" },
        "modalidad": {
          "type": "object",
          "properties": {
            "tipo": { "type": "string" },
            "frecuencia": { "type": "string" },
            "precio": { "type": "number" }
          }
        },
        "tipo": { "type": "string", "enum": ["consulta", "solicitud_inscripcion"] },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "estado": { "type": "string", "enum": ["pendiente", "contactado", "finalizado"] },
        "aceptoTerminos": { "type": "boolean" }
      },
      "required": ["nombre", "email", "telefono", "cursoId", "tipo", "fechaSolicitud"]
    },
    "pagos_mensuales": {
      "title": "Pago Mensual",
      "description": "Registro de la aportación mensual de 15€",
      "type": "object",
      "properties": {
        "socioId": { "type": "string", "description": "DNI del socio" },
        "mes": { "type": "number" },
        "anio": { "type": "number" },
        "pagado": { "type": "boolean", "description": "Si ha pagado la aportación de 15€ este mes" },
        "actualizadoPor": { "type": "string" },
        "fechaActualizacion": { "type": "string", "format": "date-time" }
      },
      "required": ["socioId", "mes", "anio"]
    },
    "pagos_inscripciones": {
      "title": "Pago Inscripción",
      "description": "Pago único por inscribirse en un curso",
      "type": "object",
      "properties": {
        "socioId": { "type": "string" },
        "cursoId": { "type": "string" },
        "pagado": { "type": "boolean" },
        "fechaPago": { "type": "string", "format": "date-time" }
      },
      "required": ["socioId", "cursoId"]
    },
    "socios": {
      "title": "Socio",
      "description": "Miembros de la asociación",
      "type": "object",
      "properties": {
        "dni": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "fechaUltimaActividad": { "type": "string", "format": "date-time" },
        "cursos": { "type": "array", "items": { "type": "string" } },
        "membresias": { "type": "object", "description": "Mapa de categorías y fechas de expiración" }
      }
    },
    "eventos": {
      "title": "Evento",
      "description": "Eventos y conciertos",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" },
        "precio_estandar": { "type": "number" },
        "tiene_descuento": { "type": "boolean" },
        "precio_descuento": { "type": "number", "description": "Precio para soci@s" },
        "clave_descuento": { "type": "string" },
        "precio_clave": { "type": "number", "description": "Precio usando la clave" },
        "apertura_socios": { "type": "string", "format": "date-time" },
        "apertura_general": { "type": "string", "format": "date-time" },
        "aforo_max": { "type": "number" },
        "aforo_actual": { "type": "number" },
        "imagenUrl": { "type": "string" },
        "descripcion": { "type": "string" },
        "categoria": { "type": "string" }
      }
    },
    "asistencia_eventos": {
      "title": "Asistencia Evento",
      "description": "Registro de check-in en eventos",
      "type": "object",
      "properties": {
        "eventoId": { "type": "string" },
        "socioId": { "type": "string", "description": "DNI del socio (opcional para walk-ins)" },
        "nombre": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" },
        "precio": { "type": "number" },
        "tipo": { "type": "string", "enum": ["socio", "walk-in", "socio_reserva"] }
      }
    },
    "caja_eventos": {
      "title": "Caja Eventos",
      "description": "Resumen de recaudación mensual por eventos",
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "ultimaActualizacion": { "type": "string", "format": "date-time" }
      }
    },
    "academias": {
      "title": "Academia",
      "description": "Paneles principales de la Home (Music is Cool, Club de Baile, etc.)",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "lema": { "type": "string" },
        "imageUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "orden": { "type": "number" },
        "activo": { "type": "boolean" }
      },
      "required": ["nombre", "lema", "imageUrl", "orden", "activo"]
    },
    "sesiones_curso": {
      "title": "Sesión de Curso",
      "description": "Clase individual de un curso",
      "type": "object",
      "properties": {
        "fecha": { "type": "string", "format": "date" },
        "hora_inicio": { "type": "string" },
        "hora_fin": { "type": "string" },
        "sala": { "type": "string", "default": "Sala Grande" }
      },
      "required": ["fecha", "hora_inicio", "hora_fin", "sala"]
    }
  },
  "firestore": {
    "/profesores/{uid}": {
      "schema": "profesores",
      "description": "Colección de profesores"
    },
    "/cursos/{cursoId}": {
      "schema": "cursos",
      "description": "Colección de cursos"
    },
    "/pagos_mensuales/{pagoId}": {
      "schema": "pagos_mensuales",
      "description": "Aportación mensual (ID: anio_mes_dni)"
    },
    "/pagos_inscripciones/{pagoId}": {
      "schema": "pagos_inscripciones",
      "description": "Pago único por curso (ID: dni_cursoId)"
    },
    "/socios/{dni}": {
      "schema": "socios",
      "description": "Colección de socios"
    },
    "/eventos/{eventoId}": {
      "schema": "eventos",
      "description": "Colección de eventos"
    },
    "/asistencia_eventos/{asistenciaId}": {
      "schema": "asistencia_eventos",
      "description": "Registro de check-in (ID: eventoId_socioId o auto)"
    },
    "/caja_eventos/{mesAnio}": {
      "schema": "caja_eventos",
      "description": "Recaudación mensual (ID: YYYY-MM)"
    },
    "/solicitudes_cursos/{solicitudId}": {
      "schema": "solicitudes_cursos",
      "description": "Colección de solicitudes de cursos"
    },
    "/academias/{academiaId}": {
      "schema": "academias",
      "description": "Colección de academias dinámicas"
    },
    "/cursos/{cursoId}/sesiones/{sesionId}": {
      "schema": "sesiones_curso",
      "description": "Sesiones de un curso (clases)"
    }
  }
}
