rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kalianrobot@gmail.com" ||
        (
          exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isTeacherOf(cursoId) {
      return isAuthenticated() &&
        exists(/databases/(default)/documents/cursos/$(cursoId)) &&
        firestore.get(/databases/(default)/documents/cursos/$(cursoId)).data.profesorId == request.auth.uid;
    }

    function isSocio() {
      return isAuthenticated() && (
        (
          exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'socio'
        ) ||
        exists(/databases/(default)/documents/socios/$(request.auth.uid))
      );
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isDocOrImage() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('text/plain');
    }

    // CURSOS: documentos de clase
    match /cursos/{cursoId}/{fileName} {
      allow read: if isAuthenticated() && (isSocio() || isTeacherOf(cursoId) || isAdmin());
      allow write: if isAuthenticated() &&
                   (isTeacherOf(cursoId) || isAdmin()) &&
                   request.resource.size < 20 * 1024 * 1024 &&
                   isDocOrImage();
      allow delete: if isAuthenticated() && (isTeacherOf(cursoId) || isAdmin());
    }

    // ACADEMIAS: imágenes de portada de academias
    match /academias/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 5 * 1024 * 1024 && isImage();
      allow delete: if isAdmin();
    }

    // CONFIG: logo, hero, galería, hub — solo admin
    match /config/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 5 * 1024 * 1024 && isImage();
      allow delete: if isAdmin();
    }

    // EVENTOS: carteles de eventos
    match /eventos/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && isImage();
      allow delete: if isAdmin();
    }

    // EXPOSICIONES: imágenes de galería
    match /exposiciones/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && isImage();
      allow delete: if isAdmin();
    }
  }
}
