rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isAuthenticated() && request.auth.token.email == "kalianrobot@gmail.com";
    }

    function isAdmin() {
      return isMasterAdmin() || (
        isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isTeacherOf(cursoId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/cursos/$(cursoId)) &&
        firestore.get(/databases/(default)/documents/cursos/$(cursoId)).data.profesorId == request.auth.uid;
    }

    // Checks users/{uid}.role — socios collection uses DNI as doc ID, not UID
    function isMember() {
      return isAuthenticated() && (
        isMasterAdmin() ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in
           ['socio', 'teacher', 'teacher_admin', 'portero', 'admin'])
      );
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isDocOrImage() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('text/plain');
    }

    // Site config images (logo, hero, gallery, hub)
    match /config/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Event posters — shown publicly on landing page and socio portal
    match /eventos/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Academia images
    match /academias/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Professor profile images
    match /profesores/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Exhibition images
    match /exposiciones/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Local/space images
    match /locales/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // Course materials: any file type allowed (PDFs, videos, etc.)
    match /cursos/{cursoId}/{fileName} {
      allow read: if isAuthenticated() && (isMember() || isTeacherOf(cursoId) || isAdmin());
      allow write: if isAuthenticated() &&
                   (isTeacherOf(cursoId) || isAdmin()) &&
                   request.resource.size < 20 * 1024 * 1024 &&
                   isDocOrImage();
      allow delete: if isAuthenticated() && (isTeacherOf(cursoId) || isAdmin());
    }
  }
}
