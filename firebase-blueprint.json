{
  "entities": {
    "profesores": {
      "title": "Profesor",
      "description": "Información de los profesores de la asociación",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID de Firebase Auth" },
        "nombre": { "type": "string", "description": "Nombre completo" },
        "email": { "type": "string", "format": "email" },
        "especialidad": { "type": "string" },
        "activo": { "type": "boolean" }
      },
      "required": ["uid", "nombre", "email"]
    },
    "cursos": {
      "title": "Curso",
      "description": "Cursos y talleres ofrecidos",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "profesorId": { "type": "string", "description": "UID del profesor asignado" },
        "profesorNombre": { "type": "string" },
        "categoria": { "type": "string", "enum": ["musica", "danza", "local"] },
        "alumnos": { "type": "array", "items": { "type": "string" }, "description": "Lista de DNIs de alumnos" },
        "aforo_disponible": { "type": "boolean" },
        "aforo_actual": { "type": "number" },
        "precio": { "type": "number" },
        "horario": { "type": "string" }
      }
    },
    "pagos_mensuales": {
      "title": "Pago Mensual",
      "description": "Registro de la aportación mensual de 15€",
      "type": "object",
      "properties": {
        "socioId": { "type": "string", "description": "DNI del socio" },
        "mes": { "type": "number" },
        "anio": { "type": "number" },
        "pagado": { "type": "boolean", "description": "Si ha pagado la aportación de 15€ este mes" },
        "actualizadoPor": { "type": "string" },
        "fechaActualizacion": { "type": "string", "format": "date-time" }
      },
      "required": ["socioId", "mes", "anio"]
    },
    "pagos_inscripciones": {
      "title": "Pago Inscripción",
      "description": "Pago único por inscribirse en un curso",
      "type": "object",
      "properties": {
        "socioId": { "type": "string" },
        "cursoId": { "type": "string" },
        "pagado": { "type": "boolean" },
        "fechaPago": { "type": "string", "format": "date-time" }
      },
      "required": ["socioId", "cursoId"]
    },
    "socios": {
      "title": "Socio",
      "description": "Miembros de la asociación",
      "type": "object",
      "properties": {
        "dni": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "estado": { "type": "string", "enum": ["activo", "inactivo"] },
        "fechaUltimaActividad": { "type": "string", "format": "date-time" },
        "cursos": { "type": "array", "items": { "type": "string" } },
        "expiraciones": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/profesores/{uid}": {
      "schema": "profesores",
      "description": "Colección de profesores"
    },
    "/cursos/{cursoId}": {
      "schema": "cursos",
      "description": "Colección de cursos"
    },
    "/pagos_mensuales/{pagoId}": {
      "schema": "pagos_mensuales",
      "description": "Aportación mensual (ID: anio_mes_dni)"
    },
    "/pagos_inscripciones/{pagoId}": {
      "schema": "pagos_inscripciones",
      "description": "Pago único por curso (ID: dni_cursoId)"
    },
    "/socios/{dni}": {
      "schema": "socios",
      "description": "Colección de socios"
    }
  }
}
